{
  "name": "vincentntang.com",
  "description": "Personal website running on Gatsby, React, and Node.js.",
  "version": "1.0.1",
  "author": "Vincent Tang <vincentntang@gmail.com>",
  "repository": "git@github.com:vincentntang/vincentntang.com",
  "dependencies": {
    "animate.css": "^4.1.1",
    "gatsby": "^2.32.13",
    "gatsby-image": "^2.11.0",
    "gatsby-plugin-catch-links": "^2.10.0",
    "gatsby-plugin-feed": "^2.13.1",
    "gatsby-plugin-google-analytics": "^2.11.0",
    "gatsby-plugin-manifest": "^2.12.1",
    "gatsby-plugin-netlify": "^2.11.1",
    "gatsby-plugin-nprogress": "^2.10.0",
    "gatsby-plugin-offline": "^2.2.10",
    "gatsby-plugin-react-helmet": "3.1.0",
    "gatsby-plugin-sass": "^2.8.0",
    "gatsby-plugin-sharp": "^2.14.4",
    "gatsby-plugin-sitemap": "2.2.1",
    "gatsby-plugin-twitter": "^2.10.0",
    "gatsby-plugin-typography": "^2.12.0",
    "gatsby-remark-autolink-headers": "^2.11.0",
    "gatsby-remark-copy-linked-files": "^2.10.0",
    "gatsby-remark-images": "3.1.3",
    "gatsby-remark-prismjs": "3.3.1",
    "gatsby-source-filesystem": "^2.11.1",
    "gatsby-transformer-json": "^2.11.0",
    "gatsby-transformer-remark": "2.6.2",
    "gatsby-transformer-sharp": "2.2.1",
    "lodash": "^4.17.21",
    "lodash.kebabcase": "^4.1.1",
    "moment": "^2.29.4",
    "node-sass": "^4.14.1",
    "prismjs": "^1.29.0",
    "react": "^16.14.0",
    "react-animate-on-scroll": "^2.1.5",
    "react-dom": "^16.14.0",
    "react-github-btn": "^1.4.0",
    "react-helmet": "^5.2.0",
    "react-typography": "^0.16.20",
    "sharp": "^0.22.1",
    "typography": "^0.16.21",
    "url-join": "^4.0.0"
  },
  "devDependencies": {
    "babel-eslint": "^10.1.0",
    "cli-glob": "^0.1.0",
    "eslint": "^6.8.0",
    "eslint-config-airbnb": "^17.1.0",
    "eslint-config-prettier": "6.0.0",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-jsx-a11y": "^6.6.1",
    "eslint-plugin-react": "^7.31.11",
    "prettier": "^1.19.1",
    "remark-cli": "^6.0.1",
    "remark-preset-lint-recommended": "^3.0.4",
    "stylefmt": "^6.0.3",
    "stylelint": "^10.1.0",
    "stylelint-config-standard": "^18.0.0",
    "write-good": "^1.0.8"
  },
  "keywords": [
    "vincent tang",
    "development",
    "dev",
    "tutorials",
    "tech",
    "articles",
    "blog"
  ],
  "license": "MIT",
  "main": "n/a",
  "scripts": {
    "develop": "gatsby develop",
    "dev": "yarn run develop",
    "serve": "gatsby serve",
    "build": "gatsby build",
    "build:pp": "gatsby build --prefix-paths",
    "build:gh": "yarn run clean && yarn run build:pp && gh-pages -d public",
    "clean": "rm -rf public && rm -rf .cache",
    "lint:js": "eslint --ext .js,.jsx .",
    "lint:md": "remark content/posts/",
    "write-good": "write-good $(glob 'content/posts/*.md')",
    "format:js": "prettier '**/*.{js,jsx}' --write",
    "check": "npx npm-check-updates -u"
  },
  "remarkConfig": {
    "plugins": [
      "remark-preset-lint-recommended"
    ]
  }
}
